{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "type": { "type": "string", "enum": ["connected_to", "depends_on", "managed_by", "trusts", "exposed_to"] },
          "confidence": { "type": "string", "enum": ["confirmed", "planned", "speculative"] }
        },
        "required": ["source", "target", "type"]
      }
    }
  },
  "required": ["relations"]
}
