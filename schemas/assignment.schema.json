{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "assignments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role": { "type": "string" },
          "device": { "type": "string" }
        },
        "required": ["role", "device"]
      }
    }
  },
  "required": ["assignments"]
}
